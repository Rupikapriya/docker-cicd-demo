pipeline {
    agent any

    stages {

        stage('Checkout') {
    steps {
        git url: 'https://github.com/Rupikapriya/docker-cicd-demo.git', branch: 'main'
    }
}

        stage('Test') {
            steps {
                sh 'echo "Running tests..."'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t myapp:latest .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d --name myapp_container myapp:latest'
            }
        }
    }
}
